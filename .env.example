# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=control_finance

PUBLIC_URL=https://your-domain.com

# Docker
RESTART_POLICY=unless-stopped
UID=1000
GID=1000

# Backend app
NODE_ENV=dev
DATABASE_URL=postgresql://postgres:change_me@db:5432/control_finance

JWT_ACCESS_SECRET=replace_with_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_long_random_string_min_32_chars
ACCESS_EXPIRES=15m
REFRESH_EXPIRES=7d

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=your_email@example.com
MAIL_PASS=your_app_password
MAIL_FROM="Control Finance <no-reply@example.com>"

# reCAPTCHA backend
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_SCORE_THRESHOLD=0.8
RECAPTCHA_ENABLED=true

# Frontend (Vite)
VITE_PUBLIC_URL=${PUBLIC_URL}
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key